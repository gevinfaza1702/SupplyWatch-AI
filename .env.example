# =============================================================================
# SupplyWatch AI — Environment Variables (EXAMPLE)
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. NEVER put secret keys in NEXT_PUBLIC_* variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# These two are safe to expose to the browser (used by the public anon client).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
# Supabase's newer dashboards label this the "publishable" key; older ones call
# it the "anon" key. Either value works here.
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-publishable-key"

# SERVER-ONLY. Full admin access, bypasses RLS. Used only in lib/supabase/admin.ts
# and trusted server routes (e.g. data import). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# -----------------------------------------------------------------------------
# AI Provider (abstraction layer — switch providers via AI_PROVIDER)
# Default for this project: Sumopod (OpenAI-compatible) with MiniMax-M2.7-highspeed.
# Supported values: "sumopod" | "openai" | "gemini"
# -----------------------------------------------------------------------------
AI_PROVIDER="sumopod"
AI_MODEL="your-model-name"

# Sumopod (OpenAI-compatible). SERVER-ONLY.
# NOTE: Confirm the exact base URL from your Sumopod dashboard if it changes.
SUMOPOD_API_KEY="your-sumopod-api-key"
SUMOPOD_BASE_URL="https://ai.sumopod.com/v1"

# OpenAI (alternative provider). SERVER-ONLY.
OPENAI_API_KEY="your-openai-api-key"

# Gemini (alternative provider). SERVER-ONLY.
GEMINI_API_KEY="your-gemini-api-key"

# -----------------------------------------------------------------------------
# Data import protection (dev/admin only)
# -----------------------------------------------------------------------------
# A simple shared secret to protect POST /api/import/run. SERVER-ONLY.
ADMIN_IMPORT_TOKEN="generate-a-long-random-string"

# -----------------------------------------------------------------------------
# Real data source URLs (Phase 4). Leave blank to use mock data (safe default).
# Point each at the PUBLISHED data file (CSV/XLSX) — do NOT scrape pages.
# When unset, the adapter reports "not configured" and the runner falls back to
# mock. Column mappings are scaffolded with TODOs (see lib/data-sources/*).
# -----------------------------------------------------------------------------
# World Bank "Pink Sheet" Excel workbook URL (commodity prices).
WORLDBANK_DATA_URL=""
WORLDBANK_SHEET=""
# FAO Food Price Index CSV URL.
FAO_DATA_URL=""
# Bank Indonesia JISDOR (USD/IDR) CSV URL.
BI_JISDOR_URL=""

# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------
# Set to "true" to render seed/demo data without a logged-in user.
NEXT_PUBLIC_DEMO_MODE="true"
# Public base URL of the app (used for absolute links in PDF/reports).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
